{
  "manifest_version": 3,
  "name": "Сказитель — тренажёр стихосложения",
  "short_name": "Сказитель",
  "version": "0.1.0",
  "description": "Учись писать стихи через геймификацию: ритм, рифма, метафора, фонетика.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
